{
  "name": "mtm-daily-news",
  "version": "2.5.0",
  "description": "MTM community digest: Maharashtra-focused RSS, local LLM tags, static JSON + site for the MTM app",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "crawl": "node scripts/crawl.js",
    "categorize": "node scripts/process-clean.js",
    "build": "node scripts/build-site.js",
    "dev": ".venv/bin/python -m http.server 8000 --directory site --bind 0.0.0.0",
    "test": "node scripts/crawl.js && node scripts/process-clean.js && node scripts/build-site.js"
  },
  "keywords": ["mtm", "maharashtra", "msme", "rss", "digest", "github-pages"],
  "author": "MTM / Deflogicals",
  "license": "MIT",
  "dependencies": {
    "rss-parser": "^3.13.0",
    "axios": "^1.6.0",
    "@xenova/transformers": "^2.6.0",
    "node-html-parser": "^6.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/deflogicals/mtm-daily-news.github.io.git"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
